+/**
+ * @brief Check two strings for equality, up to the given length, with
+ * ascii case-insensitivity.
+ */
+        static BaseType_t prvCompareStringsCaseInsensitive( const char * s1,
+                                                            const char * s2,
+                                                            size_t n )
+        {
+            while( n-- != 0 )
+            {
+                char c1 = *s1++;
+                char c2 = *s2++;
+
+                if( ( c1 >= 'A' ) && ( c1 <= 'Z' ) )
+                {
+                    c1 += 'a' - 'A';
+                }
+
+                if( ( c2 >= 'A' ) && ( c2 <= 'Z' ) )
+                {
+                    c2 += 'a' - 'A';
+                }
+
+                if( c1 > c2 )
+                {
+                    return pdFALSE;
+                }
+
+                if( c2 > c1 )
+                {
+                    return pdFALSE;
+                }
+            }
+
+            return pdTRUE;
+        }
